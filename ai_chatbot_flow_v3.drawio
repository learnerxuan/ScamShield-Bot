        <mxCell id="phishQ" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Phishing questions&#xa;1. Suspicious link?&#xa;2. Asked for OTP / password?&#xa;3. Sender or site mismatch?&#xa;4. Urgency or threat?&#xa;5. Already clicked or entered info?" vertex="1">
          <mxGeometry x="1530" y="350" width="360" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="phishCalc" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Risk calculation&#xa;Critical if entered info&#xa;Critical if link + OTP request&#xa;Score = link(2) + OTP(3) + mismatch(2) + urgency(1)" vertex="1">
          <mxGeometry x="1930" y="350" width="300" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="parcelQ" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Parcel scam questions&#xa;1. Unexpected parcel?&#xa;2. Tracking or reschedule link?&#xa;3. Delivery or customs fee?&#xa;4. Asked to install app / APK?&#xa;5. Illegal parcel or safe account claim?&#xa;6. Already paid or installed anything?" vertex="1">
          <mxGeometry x="1530" y="490" width="360" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="parcelCalc" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Risk calculation&#xa;Critical if APK / safe account / already paid&#xa;Score = unexpected parcel(1) + link(2) + fee(2)&#xa;Link + fee request = High minimum" vertex="1">
          <mxGeometry x="1930" y="490" width="300" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="bankQ" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Bank alert questions&#xa;1. Claimed to be from your bank?&#xa;2. Asked for OTP / PIN / password?&#xa;3. Click link or call message number?&#xa;4. Transfer to safe account?&#xa;5. Already shared banking details?" vertex="1">
          <mxGeometry x="1530" y="640" width="360" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="bankCalc" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Risk calculation&#xa;Critical if safe account transfer or shared details&#xa;Score = bank claim(1) + credentials(3) + suspicious link/number(2)&#xa;Credentials request = High minimum" vertex="1">
          <mxGeometry x="1930" y="640" width="300" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="jobQ" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Job scam questions&#xa;1. Unsolicited job message?&#xa;2. Asked to pay a fee?&#xa;3. Unrealistic pay for simple tasks?&#xa;4. Asked to receive and forward money?&#xa;5. Overseas job without proper contract?&#xa;6. Deposit needed to unlock tasks?" vertex="1">
          <mxGeometry x="1530" y="770" width="360" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="jobCalc" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Risk calculation&#xa;Critical if move money / overseas no contract / task deposit&#xa;Score = unsolicited(1) + upfront fee(3) + unrealistic pay(2)&#xa;Upfront fee = High minimum" vertex="1">
          <mxGeometry x="1930" y="770" width="300" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="investQ" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Investment scam questions&#xa;1. Guaranteed or very high returns?&#xa;2. Can it be verified with SC / BNM?&#xa;3. Pressure to invest quickly?&#xa;4. Recommended by online contact?&#xa;5. Fee to withdraw profits?&#xa;6. Suspicious app or platform?" vertex="1">
          <mxGeometry x="1530" y="910" width="360" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="investCalc" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="Risk calculation&#xa;Critical if withdrawal fee&#xa;Critical if online contact + guaranteed returns + suspicious platform&#xa;Score = returns(3) + not licensed(3) + pressure(2) + contact(2) + platform(2)" vertex="1">
          <mxGeometry x="1930" y="910" width="300" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="romanceQ" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="Romance scam questions&#xa;1. Met online only?&#xa;2. Serious very quickly?&#xa;3. Refused live video verification?&#xa;4. Asked for money / crypto / gift cards?&#xa;5. Encouraged investment?&#xa;6. Already sent money or private content?" vertex="1">
